# フロントエンド開発環境用の環境変数
# このファイルを .env.development にコピーして使用

# 環境識別（ブラウザに公開される）
NEXT_PUBLIC_APP_ENV=development

# バックエンドAPI URL（サーバーサイドのみ、next.config.ts のrewrite用）
API_URL=http://localhost:8787

# Google OAuth Client ID（ステージング/本番環境で必須）
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
